          "to" : "completed"
        },
        {
          "event" : "examcalc:PolicyViolation",
          "from" : "active",
          "to" : "violation_detected"
        },
        {
          "command" : "examcalc:StartExamMode",
          "from" : "not_started",
          "to" : "pending_device_verification"
        },
        {
          "command" : "examcalc:VerifyDeviceAndPolicy",
          "from" : "pending_device_verification",
          "to" : "active"
        },
        {
          "command" : "examcalc:LockCalculator",
          "from" : "violation_detected",
          "to" : "locked"
        }
      ]
    }
