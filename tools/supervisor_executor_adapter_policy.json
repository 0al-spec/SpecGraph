    "named_filters": [
      "default_backend",
      "available",
      "missing_executable",
      "passport_diagnostic",
      "safe_for_smoke",
      "canonical_trial_blocked",
      "not_applicable_in_producer_environment",
      "runtime_environment_invalid"
