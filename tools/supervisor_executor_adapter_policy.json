    "default_environment": "local_operator_environment",
    "ci_environment": "static_publish_environment",
    "executable_probe_scope": "current_process_environment",
    "status_semantics": {
      "available": "executable_available_in_current_process_environment",
      "missing_executable": "executable_not_available_in_current_process_environment",
      "unsupported": "backend_declared_but_not_supported",
      "not_applicable_in_producer_environment": "executable_probe_not_required_for_producer_environment",
      "runtime_environment_invalid": "producer_runtime_environment_override_invalid"
    }
  },
