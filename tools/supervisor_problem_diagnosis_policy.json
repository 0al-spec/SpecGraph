{
  "artifact_kind": "supervisor_problem_diagnosis_policy",
  "schema_version": 1,
  "proposal_source": "docs/proposals/0055_supervisor_problem_diagnosis_and_recovery_planner.md",
  "repository_layout": {
    "diagnosis_artifact": "runs/supervisor_problem_diagnosis.json"
  },
  "diagnosis_contract": {
    "artifact_kind": "supervisor_problem_diagnosis",
    "schema_version": 1,
    "canonical_mutations_allowed": false,
    "tracked_artifacts_written": false,
    "required_sections": [
      "target",
      "diagnosis",
      "detected_problems",
      "safe_next_actions",
      "blocked_actions",
      "validation_plan"
    ],
    "overall_statuses": [
      "clean",
      "actionable",
      "hard_stop",
      "insufficient_evidence"
    ]
  },
  "severity_levels": [
    "informational",
    "actionable",
    "blocking"
  ],
  "problem_classes": [
    {
      "id": "runtime_residue",
      "summary": "Failed or blocked run left misleading canonical gate or metadata residue.",
      "default_severity": "actionable",
      "safe_actions": [
        "clear_failed_run_residue",
        "rerun_after_provider_recovery"
      ],
      "hard_stop_when": [
        "residue_changes_canonical_semantics"
      ]
    },
    {
      "id": "quota_or_provider_failure",
      "summary": "Nested executor failed because of provider quota, transport, or account state.",
      "default_severity": "blocking",
      "safe_actions": [
        "stop_and_report_provider_blocker",
        "retry_after_provider_reset"
      ],
      "hard_stop_when": [
        "repeated_quota_failure"
      ]
    },
    {
      "id": "split_required_candidate_without_proposal_path",
      "summary": "Rejected candidate hit atomicity, but canonical content is not itself oversized.",
      "default_severity": "actionable",
      "safe_actions": [
        "emit_split_proposal_from_atomicity_pressure"
      ],
      "hard_stop_when": [
        "split_would_alter_ontology_or_policy"
      ]
    },
    {
      "id": "false_dependency_atomicity",
      "summary": "Deterministic graph operation creates a blocking dependency that is structurally a refinement or cluster relation.",
      "default_severity": "actionable",
      "safe_actions": [
        "apply_cluster_or_refinement_safe_normalization"
      ],
      "hard_stop_when": [
        "dependency_semantics_unclear"
      ]
    },
    {
      "id": "missing_trace_contract",
      "summary": "A new or changed spec lacks a registry-backed trace contract.",
      "default_severity": "actionable",
      "safe_actions": [
        "add_registry_trace_contract_with_focused_tests"
      ],
      "hard_stop_when": [
        "runtime_implementation_claim_is_ambiguous"
      ]
    },
    {
      "id": "missing_evidence_contract",
      "summary": "A new or changed spec lacks a complete evidence chain.",
      "default_severity": "actionable",
      "safe_actions": [
        "add_evidence_registry_chain",
        "classify_accepted_evidence_gap"
      ],
      "hard_stop_when": [
        "evidence_ownership_unclear"
      ]
    },
    {
      "id": "stale_queue_pressure",
      "summary": "Proposal, refactor, or backlog pressure remains after the canonical issue was already resolved.",
      "default_severity": "actionable",
      "safe_actions": [
        "clear_scoped_queue_item_and_refresh_surfaces"
      ],
      "hard_stop_when": [
        "active_proposal_still_owns_issue"
      ]
    },
    {
      "id": "malformed_or_stale_artifact",
      "summary": "A derived artifact has the wrong shape, malformed JSON, stale source data, or incompatible contract version.",
      "default_severity": "actionable",
      "safe_actions": [
        "rebuild_surface",
        "fail_safe_with_contract_error"
      ],
      "hard_stop_when": [
        "artifact_is_canonical_input"
      ]
    },
    {
      "id": "repeated_same_failure",
      "summary": "Same problem recurs across runs and should stop automation until a prevention rule is added.",
      "default_severity": "blocking",
      "safe_actions": [
        "stop_and_emit_proposal_or_process_lesson"
      ],
      "hard_stop_when": [
        "repeated_same_failure"
      ]
    }
  ],
  "safe_action_vocabulary": [
    "clear_failed_run_residue",
    "rerun_after_provider_recovery",
    "stop_and_report_provider_blocker",
    "retry_after_provider_reset",
    "emit_split_proposal_from_atomicity_pressure",
    "apply_cluster_or_refinement_safe_normalization",
    "add_registry_trace_contract_with_focused_tests",
    "add_evidence_registry_chain",
    "classify_accepted_evidence_gap",
    "clear_scoped_queue_item_and_refresh_surfaces",
    "rebuild_surface",
    "fail_safe_with_contract_error",
    "stop_and_emit_proposal_or_process_lesson"
  ],
  "hard_stop_reasons": [
    "would_change_ontology",
    "would_change_policy",
    "would_expand_supervisor_authority",
    "would_alter_approval_boundaries",
    "would_rewrite_stable_spec_ids",
    "would_bypass_live_proposal",
    "would_approve_review_gate",
    "would_merge_pr",
    "would_write_outside_allowed_paths",
    "source_authority_unclear_or_missing",
    "repeated_same_failure_after_prior_recovery"
  ],
  "planner_contract": {
    "advisory_only": true,
    "one_recommendation_at_a_time": true,
    "prefer_smallest_deterministic_action": true,
    "may_recommend_bounded_llm_run": true,
    "must_not_loop_indefinitely": true,
    "must_not_mutate_canonical_specs": true,
    "must_not_approve_gates": true,
    "must_not_merge_prs": true
  },
  "viewer_contract_reference": "docs/supervisor_problem_diagnosis_viewer_contract.md"
}
