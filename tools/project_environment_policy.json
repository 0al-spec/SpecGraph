      "proposals_root",
      "runs_root",
      "publish_root"
    ],
    "path_policy": "repo_relative_no_parent_traversal"
  },
  "viewer_contract": {
    "artifact_path": "runs/project_environment.json",
    "compact_badge_fields": [
      "mode_label",
      "project_id",
      "core_state",
      "self_evolution",
      "project_graph"
    ],
