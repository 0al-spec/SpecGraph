      "url_shape",
      "local_filesystem_path"
    ]
  },
  "path_safety": {
    "reject_absolute_paths": true,
    "reject_parent_traversal": true,
    "reject_home_expansion": true,
    "reject_windows_drive_or_uri_colon": true
