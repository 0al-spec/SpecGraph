{
  "artifact_kind": "agent_passport_adoption_policy",
  "schema_version": 1,
  "repository_layout": {
    "surface_index_artifact": "runs/agent_surface_index.json",
    "known_passport_index_artifact": "runs/known_agent_passport_index.json",
    "verification_gap_index_artifact": "runs/agent_verification_gap_index.json",
    "verification_report_artifact": "runs/agent_passport_verification_report.json",
    "executor_adapter_index_artifact": "runs/supervisor_executor_adapter_index.json",
    "runtime_enforcement_evidence_index_artifact": "runs/agent_runtime_enforcement_evidence_index.json",
    "runtime_enforcement_evidence_artifact_dir": "runs/agent_runtime_enforcement_evidence"
  },
  "specspace_consumer_contract": {
    "consumer_id": "specspace",
    "consumer_category": "specspace_operator_surface",
    "artifact_paths": [
      "runs/supervisor_executor_adapter_index.json",
      "runs/agent_surface_index.json",
      "runs/known_agent_passport_index.json",
      "runs/agent_passport_verification_report.json",
      "runs/agent_verification_gap_index.json",
      "runs/agent_runtime_enforcement_evidence_index.json"
    ],
    "required_display_states": {
      "verification_states": [
        "V2_passport_referenced",
        "V3_schema_valid"
      ],
      "verification_gap_kinds": [
        "verification_failed",
        "verification_unavailable"
      ],
      "verification_statuses": [
        "valid",
        "invalid",
        "unavailable",
        "tool_unavailable"
      ],
      "runtime_enforcement_states": [
        "policy_only",
        "boundary_only",
        "deferred",
        "observed",
        "unknown"
      ],
      "runtime_enforcement_evidence_statuses": [
        "passed",
        "failed",
        "missing"
      ]
    },
    "required_fallbacks": [
      "producer_artifact_missing",
      "producer_artifact_schema_mismatch",
      "verification_report_unavailable",
      "runtime_enforcement_not_observed",
      "runtime_enforcement_evidence_unavailable"
    ],
    "privacy_boundary": {
      "local_only_fields_forbidden": true,
      "raw_validator_logs_forbidden": true,
      "raw_passport_material_forbidden": true,
      "raw_supervisor_logs_forbidden": true
    }
  },
  "surface_index_contract": {
    "artifact_kind": "agent_surface_index",
    "schema_version": 1,
    "stable_fields": [
      "artifact_kind",
      "schema_version",
      "summary",
      "surfaces",
      "viewer_projection"
    ],
    "named_filters": [
      "requires_passport",
      "passport_referenced",
      "missing_passport",
      "executor_backend",
      "specspace_consumer",
      "runtime_enforcement_policy_only",
      "runtime_enforcement_boundary_only",
      "runtime_enforcement_deferred",
      "runtime_enforcement_observed",
      "runtime_enforcement_unknown"
    ]
  },
  "known_passport_index_contract": {
    "artifact_kind": "known_agent_passport_index",
    "schema_version": 1,
    "stable_fields": [
      "artifact_kind",
      "schema_version",
      "summary",
      "entries",
      "agents",
      "viewer_projection"
    ]
  },
  "verification_report_contract": {
    "artifact_kind": "agent_passport_verification_report",
    "schema_version": 1,
    "stable_fields": [
      "artifact_kind",
      "schema_version",
      "summary",
      "entries",
      "viewer_projection"
    ],
    "verification_statuses": [
      "valid",
      "invalid",
      "unavailable",
      "tool_unavailable"
    ],
    "named_filters": [
      "valid",
      "invalid",
      "unavailable",
      "tool_unavailable",
      "executor_backend",
      "specspace_consumer"
    ]
  },
  "verification_gap_index_contract": {
    "artifact_kind": "agent_verification_gap_index",
    "schema_version": 1,
    "stable_fields": [
      "artifact_kind",
      "schema_version",
      "summary",
      "gaps",
      "viewer_projection"
    ],
    "gap_kinds": [
      "missing_passport",
      "verification_tool_unavailable",
      "verification_not_attempted",
      "verification_failed",
      "verification_unavailable",
      "runtime_enforcement_policy_only",
      "runtime_enforcement_boundary_only",
      "runtime_enforcement_deferred",
      "runtime_enforcement_evidence_missing",
      "runtime_enforcement_unknown"
    ],
    "severity_values": [
      "high",
      "medium",
      "low"
    ],
    "named_filters": [
      "missing_passport",
      "verification_tool_unavailable",
      "verification_failed",
      "verification_unavailable",
      "runtime_enforcement_policy_only",
      "runtime_enforcement_boundary_only",
      "runtime_enforcement_deferred",
      "runtime_enforcement_evidence_missing",
      "runtime_enforcement_unknown",
      "executor_backend",
      "specspace_consumer"
    ]
  },
  "runtime_enforcement_evidence_contract": {
    "artifact_kind": "agent_runtime_enforcement_evidence",
    "schema_version": 1,
    "status": "report_only",
    "required_fields": [
      "evidence_id",
      "agent_surface",
      "runtime_enforcement_state",
      "posture_claim",
      "evidence",
      "result"
    ],
    "accepted_evidence_kinds": [
      "policy_decision",
      "sandbox_trace",
      "runtime_smoke",
      "audit_log",
      "test_report",
      "operator_attestation"
    ],
    "privacy_boundary": {
      "machine_local_paths_forbidden": true,
      "raw_supervisor_logs_forbidden": true,
      "raw_prompts_forbidden": true,
      "secrets_forbidden": true
    },
    "posture_requirements": {
      "runtime_enforcement_policy_only": {
        "eligible_for_observed": true,
        "required_evidence_kinds": [
          "policy_decision",
          "runtime_smoke"
        ],
        "next_action": "attach_runtime_enforcement_evidence"
      },
      "runtime_enforcement_boundary_only": {
        "eligible_for_observed": true,
        "required_evidence_kinds": [
          "policy_decision",
          "audit_log"
        ],
        "next_action": "attach_consumer_boundary_enforcement_evidence"
      },
      "runtime_enforcement_deferred": {
        "eligible_for_observed": false,
        "required_evidence_kinds": [],
        "next_action": "materialize_runtime_surface_before_evidence"
      },
      "runtime_enforcement_evidence_missing": {
        "eligible_for_observed": true,
        "required_evidence_kinds": [
          "policy_decision",
          "runtime_smoke"
        ],
        "next_action": "attach_runtime_enforcement_evidence"
      }
    }
  },
  "runtime_enforcement_evidence_index_contract": {
    "artifact_kind": "agent_runtime_enforcement_evidence_index",
    "schema_version": 1,
    "stable_fields": [
      "artifact_kind",
      "schema_version",
      "summary",
      "entries",
      "viewer_projection"
    ],
    "statuses": [
      "passed",
      "failed",
      "missing"
    ],
    "named_filters": [
      "passed",
      "failed",
      "missing",
      "runtime_smoke",
      "policy_only",
      "boundary_only",
      "deferred",
      "executor_gateway"
    ]
  },
  "runtime_enforcement_evidence_smokes": [
    {
      "evidence_id": "agent_runtime_enforcement_evidence::specgraph.supervisor.executor_adapter::runtime_smoke",
      "agent_surface": "specgraph.supervisor.executor_adapter",
      "evidence_kind": "runtime_smoke",
      "artifact_path": "runs/agent_runtime_enforcement_evidence/supervisor-executor-adapter-smoke.json",
      "posture_claim": "runtime_enforcement_policy_only",
      "runtime_enforcement_state": "policy_only",
      "source_proposal_ids": [
        "0056",
        "0059",
        "0076",
        "0077",
        "0080"
      ],
      "required_checks": [
        "agent_surface_present",
        "agent_passport_ref_declared",
        "executor_adapter_index_present",
        "evidence_ref_safe",
        "no_observed_enforcement_claim",
        "executor_adapter_invocation_boundary"
      ],
      "notes": "Report-only smoke evidence for the supervisor executor adapter gateway. It proves the derived adapter/passport surfaces are internally consistent, safe to reference, and constrained to declarative CLI executable lookup without shell command persistence; it does not prove sandbox or runtime policy enforcement."
    }
  ],
  "runtime_enforcement_states": [
    "observed",
    "policy_only",
    "boundary_only",
    "deferred",
    "unknown"
  ],
  "verification_states": [
    "V0_unknown",
    "V1_known_surface",
    "V2_passport_referenced",
    "V3_schema_valid",
    "V4_signature_verified",
    "V5_lifecycle_valid",
    "V6_integrity_declared",
    "V7_policies_mappable",
    "V8_runtime_enforcement_observed"
  ],
  "agent_surfaces": [
    {
      "surface_id": "specgraph.supervisor",
      "title": "SpecGraph Supervisor",
      "surface_type": "graph_runtime",
      "source": "policy",
      "source_proposal_ids": [
        "0059"
      ],
      "requires_passport": true,
      "launches_agents": true,
      "prepares_handoffs": true,
      "passport_ref": "agent-passport://specgraph/supervisor/0.1.0",
      "verification_state": "V2_passport_referenced",
      "runtime_enforcement_state": "policy_only",
      "notes": "Supervisor identity is referenced for graph-facing authority. Runtime enforcement is known to be policy-only until a dedicated enforcement runtime is introduced."
    },
    {
      "surface_id": "specgraph.supervisor.executor_adapter",
      "title": "Supervisor Executor Adapter Gateway",
      "surface_type": "executor_gateway",
      "source": "policy",
      "source_proposal_ids": [
        "0056",
        "0059"
      ],
      "requires_passport": true,
      "launches_agents": true,
      "prepares_handoffs": true,
      "passport_ref": "agent-passport://specgraph/supervisor-executor-adapter/0.1.0",
      "verification_state": "V2_passport_referenced",
      "runtime_enforcement_state": "policy_only",
      "notes": "Gateway surface launches nested executors; this declaration names the gateway authority separately from backend-specific passport refs derived from the 0056 executor adapter index. Runtime enforcement is known to be policy-only until a dedicated enforcement runtime is introduced."
    },
    {
      "surface_id": "specspace.operator_assistant",
      "title": "SpecSpace Operator Assistant",
      "surface_type": "operator_ui_flow",
      "source": "policy",
      "source_proposal_ids": [
        "0057",
        "0059",
        "0065"
      ],
      "requires_passport": true,
      "launches_agents": false,
      "prepares_handoffs": true,
      "passport_ref": "agent-passport://specspace/operator-assistant/0.1.0",
      "verification_state": "V2_passport_referenced",
      "runtime_enforcement_state": "boundary_only",
      "consumer_id": "specspace",
      "notes": "SpecSpace consumes derived surfaces and prepares operator handoffs. This graph-side reference declares the required operator assistant identity while runtime enforcement remains a consumer-boundary concern outside SpecGraph authority."
    },
    {
      "surface_id": "product_workspace.implementation_agent",
      "title": "Product Workspace Implementation Agent",
      "surface_type": "future_product_workspace_agent",
      "source": "policy",
      "source_proposal_ids": [
        "0059"
      ],
      "requires_passport": true,
      "launches_agents": true,
      "prepares_handoffs": false,
      "passport_ref": "agent-passport://product-workspace/implementation-agent/0.1.0",
      "verification_state": "V2_passport_referenced",
      "runtime_enforcement_state": "deferred",
      "future_surface": true,
      "notes": "Future product workspace agent is listed so implementation-agent identity is declared before runtime availability; runtime enforcement is explicitly deferred until the product-workspace runtime exists."
    }
  ],
  "executor_adapter_binding": {
    "enabled": true,
    "source_artifact": "runs/supervisor_executor_adapter_index.json",
    "surface_id_prefix": "specgraph.executor",
    "surface_type": "executor_backend",
    "source_proposal_ids": [
      "0056",
      "0059",
      "0066",
      "0084"
    ]
  },
  "passport_ref_registry": [
    {
      "passport_ref": "agent-passport://specgraph/supervisor/0.1.0",
      "document_path": "tools/agent_passports/specgraph-supervisor.passport.yaml"
    },
    {
      "passport_ref": "agent-passport://specgraph/supervisor-executor-adapter/0.1.0",
      "document_path": "tools/agent_passports/specgraph-supervisor-executor-adapter.passport.yaml"
    },
    {
      "passport_ref": "agent-passport://specspace/operator-assistant/0.1.0",
      "document_path": "tools/agent_passports/specspace-operator-assistant.passport.yaml"
    },
    {
      "passport_ref": "agent-passport://product-workspace/implementation-agent/0.1.0",
      "document_path": "tools/agent_passports/product-workspace-implementation-agent.passport.yaml"
    },
    {
      "passport_ref": "agent-passport://executors/codex-cli/0.1.0",
      "document_path": "tools/agent_passports/specgraph-executor-codex-cli.passport.yaml"
    }
  ],
  "gap_defaults": {
    "missing_passport": {
      "severity": "high",
      "next_action": "declare_agent_passport_ref"
    },
    "verification_tool_unavailable": {
      "severity": "medium",
      "next_action": "install_or_package_agent_passport_cli"
    },
    "verification_not_attempted": {
      "severity": "medium",
      "next_action": "run_report_only_passport_verification"
    },
    "verification_failed": {
      "severity": "medium",
      "next_action": "repair_agent_passport_document"
    },
    "verification_unavailable": {
      "severity": "medium",
      "next_action": "provide_agent_passport_document"
    },
    "runtime_enforcement_policy_only": {
      "severity": "low",
      "next_action": "define_runtime_enforcement_runtime"
    },
    "runtime_enforcement_boundary_only": {
      "severity": "low",
      "next_action": "define_consumer_boundary_enforcement_contract"
    },
    "runtime_enforcement_deferred": {
      "severity": "low",
      "next_action": "wait_for_runtime_surface_before_enforcement"
    },
    "runtime_enforcement_evidence_missing": {
      "severity": "medium",
      "next_action": "attach_runtime_enforcement_evidence"
    },
    "runtime_enforcement_unknown": {
      "severity": "low",
      "next_action": "classify_runtime_enforcement_posture"
    }
  },
  "privacy_boundary": {
    "raw_passport_material_forbidden": true,
    "raw_validator_logs_forbidden": true,
    "machine_local_paths_forbidden": true,
    "secrets_forbidden": true
  }
}
